{
  "os_name": "Amazon Linux 2023",
  "os_version": "2023",
  "tests": [

    {
      "index": 0,
      "command": "apt-get install nginx",
      "exit_status": 1,
      "stdout": "",
      "stderr": "apt-get: command not found"
    },

    {
      "index": 1,
      "command": "dnf install",
      "exit_status": 1,
      "stdout": "",
      "stderr": "Error: Need to pass a list of packages"
    },

    {
      "index": 2,
      "command": "dnf install -y nginx",
      "exit_status": 1,
      "stdout": "",
      "stderr": "Failed to download metadata for repo 'amzn2023-core'"
    },

    {
      "index": 3,
      "command": "dnf install -y nginx",
      "exit_status": 1,
      "stdout": "",
      "stderr": "Cannot prepare internal mirrorlist: No URLs in mirrorlist"
    },

    {
      "index": 4,
      "command": "dnf install -y nginx",
      "exit_status": 1,
      "stdout": "",
      "stderr": "Error: failed to download metadata for repo 'amzn2023-extras'"
    },

    {
      "index": 5,
      "command": "dnf install -y nginx",
      "exit_status": 1,
      "stdout": "",
      "stderr": "Error: No matching repo: amzn2023-php"
    },

    {
      "index": 6,
      "command": "dnf install -y nginx",
      "exit_status": 1,
      "stdout": "",
      "stderr": "rpmdb open failed"
    },

    {
      "index": 7,
      "command": "dnf install -y nginx",
      "exit_status": 1,
      "stdout": "",
      "stderr": "BDB0113 Thread/process died"
    },

    {
      "index": 8,
      "command": "dnf install -y nginx",
      "exit_status": 1,
      "stdout": "",
      "stderr": "Could not resolve host: mirror.amazonlinux.com"
    },

    {
      "index": 9,
      "command": "dnf install -y nginx",
      "exit_status": 1,
      "stdout": "",
      "stderr": "Connection timed out"
    },

    {
      "index": 10,
      "command": "dnf install -y nginx",
      "exit_status": 1,
      "stdout": "",
      "stderr": "Package nginx is already installed.\nNothing to do."
    },

    {
      "index": 11,
      "command": "dnf update -y",
      "exit_status": 0,
      "stdout": "",
      "stderr": "Nothing to do."
    },

    {
      "index": 12,
      "command": "dnf upgrade -y",
      "exit_status": 0,
      "stdout": "",
      "stderr": "No packages marked for update."
    },

    {
      "index": 13,
      "command": "show ip interface brief",
      "exit_status": 127,
      "stdout": "",
      "stderr": "show: command not found"
    },

    {
      "index": 14,
      "command": "rm -rf /",
      "exit_status": 1,
      "stdout": "",
      "stderr": "rm: cannot remove '/': Permission denied"
    },

    {
      "index": 15,
      "command": "dnf install -y htop",
      "exit_status": 0,
      "stdout": "Installed: htop",
      "stderr": ""
    }
